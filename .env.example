# MongoDB connection string (required)
MONGO_URI=mongodb://localhost:27017/workflowforge

# JWT secret key (required - use a strong random string in production)
JWT_SECRET=changeme_dev_secret

# Server port
PORT=5000

# Environment
NODE_ENV=development

# Frontend URL for CORS (required in production)
FRONTEND_URL=http://localhost:5173

# Disable Redis/BullMQ queue (set to true if no Redis available)
DISABLE_QUEUE=true
